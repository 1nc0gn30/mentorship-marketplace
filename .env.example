# --- Unstuck backend config (test mode) ---
# Copy to .env and fill in. .env is gitignored.

# Stripe TEST secret key (from `stripe config --list` -> test_mode_api_key).
# Payment Links are created in test mode, so no real charges ever happen.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret from `stripe listen --print-secret`
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
